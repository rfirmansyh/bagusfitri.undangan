{
	"name": "kondangan-next",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "next dev",
		"build": "next build",
		"start": "next start",
		"lint": "next lint",
		"deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
		"upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
		"preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
		"cf-typegen": "wrangler types --env-interface CloudflareEnv ./cloudflare-env.d.ts",
		"d1:migrate:local": "wrangler d1 migrations apply kondangan --local",
		"d1:migrate:remote": "wrangler d1 migrations apply kondangan --remote",
		"d1:reset:local": "wrangler d1 execute kondangan --local --command \"DELETE FROM rsvps; DELETE FROM wishes;\"",
		"d1:reset:remote": "wrangler d1 execute kondangan --remote --command \"DELETE FROM rsvps; DELETE FROM wishes;\""
	},
	"dependencies": {
		"@hookform/resolvers": "^5.2.2",
		"@opennextjs/cloudflare": "^1.19.9",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"lucide-react": "^1.16.0",
		"next": "16.2.6",
		"next-themes": "^0.4.6",
		"radix-ui": "^1.4.3",
		"react": "^19.1.7",
		"react-dom": "^19.1.7",
		"react-hook-form": "^7.76.0",
		"shadcn": "^4.7.0",
		"sonner": "^2.0.7",
		"tailwind-merge": "^3.6.0",
		"tw-animate-css": "^1.4.0",
		"yup": "^1.7.1"
	},
	"devDependencies": {
		"@eslint/eslintrc": "^3",
		"@tailwindcss/postcss": "^4",
		"@trivago/prettier-plugin-sort-imports": "^6.0.2",
		"@types/node": "^20",
		"@types/react": "^19.1.7",
		"@types/react-dom": "^19.1.7",
		"eslint": "^9",
		"eslint-config-next": "16.2.6",
		"eslint-plugin-react": "^7.37.5",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"tailwindcss": "^4",
		"typescript": "^5.7.4",
		"wrangler": "^4.93.0"
	}
}